
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      // Student's quiz attempts
      match /quizAttempts/{attemptId} {
        // Owner can always read/write
        allow read, write: if isOwner(userId);
        
        // Teachers can read attempts for their own assigned quizzes/classes
        allow read: if isSignedIn();
      }
    }

    // Classes and their content
    // Broadened for prototype reliability
    // Deployment trigger: Atomic CRUD definitions applied
    match /classes/{classId} {
      // Allow any signed-in user to read and update (for studentIds array enrollment)
      allow read, create, update: if isSignedIn();
      // Restrict deletion to the owner/teacher
      allow delete: if isSignedIn() && (resource.data.teacherId == request.auth.uid);

      // Broad permissions for sub-collections within a class
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      // Check request.resource for creation, and resource for updates
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participantIds);
      allow read, update: if isSignedIn() && (request.auth.uid in resource.data.participantIds);

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Global Collection Group Rules ---
    
    match /{path=**}/notes/{noteId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/quizAttempts/{attemptId} {
      allow list, get: if isSignedIn();
    }
  }
}
