
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Global Prototyping Rule ---
    // Explicitly allow all read/write operations for authenticated users to ensure 
    // smooth prototyping and prevent "Missing or insufficient permissions" errors.
    // Deployment trigger: Atomic broad-access policy applied.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Specific match blocks for clarity and future refinement
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /classes/{classId} {
      allow read, write: if isSignedIn();
    }

    match /chatSessions/{sessionId} {
      allow read, write: if isSignedIn();
    }
  }
}
