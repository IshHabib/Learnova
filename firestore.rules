
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      // Student's quiz attempts
      match /quizAttempts/{attemptId} {
        // Owner can always read/write
        allow read, write: if isOwner(userId);
        
        // Teachers can read attempts for their own assigned quizzes/classes
        allow read: if isSignedIn() && (
          resource.data.teacherId == request.auth.uid || 
          resource.data.classTeacherId == request.auth.uid
        );
      }
    }

    // Classes and their content
    match /classes/{classId} {
      // Broad read for all signed in users
      allow read: if isSignedIn();
      
      // Allow any signed in user to create a class (required for teachers)
      allow create: if isSignedIn();
      
      // Allow any signed in user to update a class 
      // This is CRITICAL for enrollment (students updating studentIds array)
      allow update: if isSignedIn();
      
      // Only the teacher who created the class can delete it
      allow delete: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid
      );

      // Sub-collections: broad permissions for prototype functionality
      match /notes/{id} { 
        allow read, write: if isSignedIn();
      }
      match /videos/{id} { 
        allow read, write: if isSignedIn();
      }
      match /quizzes/{id} { 
        allow read, write: if isSignedIn();
      }
      match /studyGroups/{id} { 
        allow read, write: if isSignedIn();
      }
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow read, write: if isSignedIn() && (request.auth.uid in resource.data.participantIds);

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Global Collection Group Rules ---
    
    match /{path=**}/notes/{noteId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/quizAttempts/{attemptId} {
      allow list: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || 
        resource.data.teacherId == request.auth.uid ||
        resource.data.classTeacherId == request.auth.uid
      );
      allow get: if isSignedIn();
    }
  }
}
