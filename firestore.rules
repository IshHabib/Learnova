rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User profiles - allow read for all signed-in users so they can see names
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Quiz attempts - Specific path for students
    match /users/{userId}/quizAttempts/{attemptId} {
      // Split read into get and list to avoid query constraint issues for owners
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow create: if isOwner(userId);
    }

    // Global Collection Group rules for cross-class content
    // Splitting OR conditions into separate allow statements helps the query optimizer
    
    match /{path=**}/quizAttempts/{attemptId} {
      allow list: if isSignedIn() && resource.data.studentId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.teacherId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid);
    }

    match /{path=**}/notes/{noteId} {
      allow list: if isSignedIn() && request.auth.uid in resource.data.classStudentIds;
      allow list: if isSignedIn() && resource.data.classTeacherId == request.auth.uid;
      allow get: if isSignedIn();
    }

    match /{path=**}/videos/{videoId} {
      allow list: if isSignedIn() && request.auth.uid in resource.data.classStudentIds;
      allow list: if isSignedIn() && resource.data.classTeacherId == request.auth.uid;
      allow get: if isSignedIn();
    }

    match /{path=**}/quizzes/{quizId} {
      allow list: if isSignedIn() && request.auth.uid in resource.data.classStudentIds;
      allow list: if isSignedIn() && resource.data.classTeacherId == request.auth.uid;
      allow get: if isSignedIn();
    }

    match /{path=**}/studyGroups/{groupId} {
      allow list: if isSignedIn() && request.auth.uid in resource.data.classStudentIds;
      allow list: if isSignedIn() && resource.data.classTeacherId == request.auth.uid;
      allow get: if isSignedIn();
    }

    // Specific path rules for writes (Teachers only)
    match /classes/{classId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds'])
      );
      allow delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;
    }

    match /classes/{classId}/notes/{noteId} {
      allow write: if isSignedIn() && (
        request.resource.data.classTeacherId == request.auth.uid ||
        get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
      );
    }

    match /classes/{classId}/videos/{videoId} {
      allow write: if isSignedIn() && (
        request.resource.data.classTeacherId == request.auth.uid ||
        get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
      );
    }

    match /classes/{classId}/quizzes/{quizId} {
      allow write: if isSignedIn() && (
        request.resource.data.classTeacherId == request.auth.uid ||
        get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
      );
    }

    match /classes/{classId}/studyGroups/{groupId} {
      allow write: if isSignedIn() && (
        request.resource.data.classTeacherId == request.auth.uid ||
        get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
      );
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
    }

    // Messages
    match /chatSessions/{sessionId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.participantIds);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }
  }
}