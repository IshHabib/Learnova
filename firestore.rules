rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User profiles - allow read for all signed-in users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      // Student's own quiz attempts
      match /quizAttempts/{attemptId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Classes - readable by all signed-in users (to allow joining)
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds'])
      );
      allow delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;

      // Sub-collections under a specific class
      match /notes/{id} { allow read, write: if isSignedIn(); }
      match /videos/{id} { allow read, write: if isSignedIn(); }
      match /quizzes/{id} { allow read, write: if isSignedIn(); }
      match /studyGroups/{id} { allow read, write: if isSignedIn(); }
    }

    // Collection Group rules for cross-class queries
    // NOTE: These rules require queries to be "provably safe" with matching .where() filters
    
    match /{path=**}/notes/{noteId} {
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow get: if isSignedIn();
    }

    match /{path=**}/videos/{videoId} {
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow get: if isSignedIn();
    }

    match /{path=**}/quizzes/{quizId} {
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow get: if isSignedIn();
    }

    match /{path=**}/studyGroups/{groupId} {
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow get: if isSignedIn();
    }

    match /{path=**}/quizAttempts/{attemptId} {
      // Split list rules to avoid "OR" logic complexity in "provably safe" checks
      allow list: if isSignedIn() && resource.data.studentId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.teacherId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
    }

    // Messages
    match /chatSessions/{sessionId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.participantIds);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }
  }
}