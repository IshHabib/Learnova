rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User profiles - allow read for all signed-in users so they can see names
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Quiz attempts - Specific path for students
    match /users/{userId}/quizAttempts/{attemptId} {
      allow read: if isOwner(userId) || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow create: if isOwner(userId);
    }

    // Quiz attempts - Collection Group rule for teachers to see all attempts
    match /{path=**}/quizAttempts/{attemptId} {
      allow list: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || 
        resource.data.teacherId == request.auth.uid
      );
    }

    // Classes
    match /classes/{classId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds'])
      );
      allow delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;
    }

    // Notes
    match /classes/{classId}/notes/{noteId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
      );
    }

    // Videos
    match /classes/{classId}/videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
      );
    }

    // Quizzes
    match /classes/{classId}/quizzes/{quizId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
      );
    }

    // Study Groups
    match /classes/{classId}/studyGroups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
      );
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
    }

    // Messages
    match /chatSessions/{sessionId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.participantIds);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }
  }
}