rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      // Student's own quiz attempts
      match /quizAttempts/{attemptId} {
        // A student can read/write their own attempts.
        // A teacher can read attempts where they are the assigned teacher.
        allow read: if isSignedIn() && (isOwner(userId) || resource.data.teacherId == request.auth.uid);
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId);
      }
    }

    // Classes
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds'])
      );
      allow delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;

      // Sub-collections - direct access for members/teachers
      match /notes/{id} { allow read, write: if isSignedIn(); }
      match /videos/{id} { allow read, write: if isSignedIn(); }
      match /quizzes/{id} { allow read, write: if isSignedIn(); }
      match /studyGroups/{id} { allow read, write: if isSignedIn(); }
    }

    // --- Collection Group Rules (Provably Safe for Queries) ---
    
    match /{path=**}/notes/{noteId} {
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow get: if isSignedIn();
    }

    match /{path=**}/videos/{videoId} {
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow get: if isSignedIn();
    }

    match /{path=**}/quizzes/{quizId} {
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow get: if isSignedIn();
    }

    match /{path=**}/studyGroups/{groupId} {
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow get: if isSignedIn();
    }

    match /{path=**}/quizAttempts/{attemptId} {
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participantIds);

      // Messages - Denormalized check for provably safe listing
      match /messages/{messageId} {
        allow list: if isSignedIn() && (request.auth.uid in resource.data.chatSessionParticipantIds);
        allow get: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}