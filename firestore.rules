rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      // Student's quiz attempts
      match /quizAttempts/{attemptId} {
        // Owner has full access
        allow read, write: if isOwner(userId);
        // Teacher has read access if they are assigned to the attempt
        allow read: if isSignedIn() && resource.data.teacherId == request.auth.uid;
      }
    }

    // Classes and their content
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid || 
        isOwner(resource.data.teacherId)
      );

      // Simple sub-collection access
      match /notes/{id} { allow read, write: if isSignedIn(); }
      match /videos/{id} { allow read, write: if isSignedIn(); }
      match /quizzes/{id} { allow read, write: if isSignedIn(); }
      match /studyGroups/{id} { allow read, write: if isSignedIn(); }
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow read, write: if isSignedIn() && (request.auth.uid in resource.data.participantIds);

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Global Collection Group Rules (Provably Safe for Queries) ---
    
    match /{path=**}/notes/{noteId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/quizAttempts/{attemptId} {
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid);
      allow get: if isSignedIn();
    }
  }
}