
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      // Student's quiz attempts
      match /quizAttempts/{attemptId} {
        // Owner can always read/write
        allow read, write: if isOwner(userId);
        
        // Teachers can read attempts for their own assigned quizzes/classes
        // We check both the teacherId (direct) and classTeacherId (denormalized)
        allow read: if isSignedIn() && (
          resource.data.teacherId == request.auth.uid || 
          resource.data.classTeacherId == request.auth.uid
        );
      }
    }

    // Classes and their content
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Allow any signed-in user to update (join class or manage students)
      // In a production app, we'd further restrict this to specific fields
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid
      );

      // Sub-collections
      // Permissions are kept broad for prototype functionality
      match /notes/{id} { 
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
      match /videos/{id} { 
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
      match /quizzes/{id} { 
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
      match /studyGroups/{id} { 
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow read, write: if isSignedIn() && (request.auth.uid in resource.data.participantIds);

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Global Collection Group Rules ---
    
    match /{path=**}/notes/{noteId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/quizAttempts/{attemptId} {
      allow list: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || 
        resource.data.teacherId == request.auth.uid ||
        resource.data.classTeacherId == request.auth.uid
      );
      allow get: if isSignedIn();
    }
  }
}
