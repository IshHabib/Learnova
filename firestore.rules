rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeacher(teacherId) {
      return isSignedIn() && request.auth.uid == teacherId;
    }

    function isParticipant(participants) {
      return isSignedIn() && (request.auth.uid in participants);
    }

    // --- Collection Rules ---

    // User profiles
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      // Quiz attempts subcollection
      match /quizAttempts/{attemptId} {
        // Handled by the recursive wildcard below for collectionGroup support
      }
    }

    // Generic match for all quizAttempts (supports collectionGroup)
    match /{path=**}/quizAttempts/{attemptId} {
      allow get, list: if isSignedIn() && (
        (exists(resource.data.studentId) && request.auth.uid == resource.data.studentId) || 
        (exists(resource.data.teacherId) && request.auth.uid == resource.data.teacherId)
      );
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
    }

    // Classes
    match /classes/{classId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds']))
      );
      allow delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;
    }

    // Notes (supports collectionGroup)
    match /{path=**}/notes/{noteId} {
      allow get, list: if isSignedIn() && (
        (resource.data.classTeacherId == request.auth.uid) || 
        (request.auth.uid in resource.data.classStudentIds)
      );
      allow create: if isSignedIn() && request.resource.data.classTeacherId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.classTeacherId == request.auth.uid;
    }

    // Videos (supports collectionGroup)
    match /{path=**}/videos/{videoId} {
      allow get, list: if isSignedIn() && (
        (resource.data.classTeacherId == request.auth.uid) || 
        (request.auth.uid in resource.data.classStudentIds)
      );
      allow create: if isSignedIn() && request.resource.data.classTeacherId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.classTeacherId == request.auth.uid;
    }

    // Quizzes (supports collectionGroup)
    match /{path=**}/quizzes/{quizId} {
      allow get, list: if isSignedIn() && (
        (resource.data.classTeacherId == request.auth.uid) || 
        (request.auth.uid in resource.data.classStudentIds)
      );
      allow create: if isSignedIn() && request.resource.data.classTeacherId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.classTeacherId == request.auth.uid;
    }

    // Study Groups (supports collectionGroup)
    match /{path=**}/studyGroups/{groupId} {
      allow get, list: if isSignedIn() && (
        (resource.data.classTeacherId == request.auth.uid) || 
        (request.auth.uid in resource.data.studentIds)
      );
      allow create: if isSignedIn() && request.resource.data.classTeacherId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.classTeacherId == request.auth.uid;
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participantIds);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
    }

    // Messages
    match /{path=**}/messages/{messageId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.chatSessionParticipantIds);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }
  }
}