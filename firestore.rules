
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      // Student's quiz attempts
      match /quizAttempts/{attemptId} {
        // Owner can always read/write
        allow read, write: if isOwner(userId);
        
        // Teachers can read attempts for their own assigned quizzes/classes
        allow read: if isSignedIn() && (
          resource.data.teacherId == request.auth.uid || 
          resource.data.classTeacherId == request.auth.uid
        );
      }
    }

    // Classes and their content
    // Broad permissions for prototype phase to allow self-enrollment and management
    match /classes/{classId} {
      // Explicitly permitting all CRUD operations for signed-in users
      // This ensures that students can 'update' the studentIds array
      allow read, create, update, delete: if isSignedIn();

      // Broad permissions for sub-collections (notes, videos, quizzes, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow read, write: if isSignedIn() && (request.auth.uid in resource.data.participantIds);

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Global Collection Group Rules ---
    
    match /{path=**}/notes/{noteId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/quizAttempts/{attemptId} {
      allow list: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || 
        resource.data.teacherId == request.auth.uid ||
        resource.data.classTeacherId == request.auth.uid
      );
      allow get: if isSignedIn();
    }
  }
}
