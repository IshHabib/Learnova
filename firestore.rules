rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User profiles - allow read for all signed-in users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      // Explicit path for subcollections to avoid "provably safe" list errors
      match /quizAttempts/{attemptId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Classes - readable by all signed-in users (to allow joining)
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds'])
      );
      allow delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;
    }

    // Sub-collections: Notes, Videos, Quizzes, StudyGroups
    match /{path=**}/notes/{noteId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow write: if isSignedIn() && (request.resource.data.classTeacherId == request.auth.uid || resource.data.classTeacherId == request.auth.uid);
    }

    match /{path=**}/videos/{videoId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow write: if isSignedIn() && (request.resource.data.classTeacherId == request.auth.uid || resource.data.classTeacherId == request.auth.uid);
    }

    match /{path=**}/quizzes/{quizId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow write: if isSignedIn() && (request.resource.data.classTeacherId == request.auth.uid || resource.data.classTeacherId == request.auth.uid);
    }

    match /{path=**}/studyGroups/{groupId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.classTeacherId == request.auth.uid || request.auth.uid in resource.data.classStudentIds);
      allow write: if isSignedIn() && (request.resource.data.classTeacherId == request.auth.uid || resource.data.classTeacherId == request.auth.uid);
    }

    // Quiz Attempts (General/Group Access)
    match /{path=**}/quizAttempts/{attemptId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
    }

    // Messages
    match /chatSessions/{sessionId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.participantIds);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }
  }
}